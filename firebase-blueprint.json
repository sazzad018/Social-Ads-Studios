{
  "entities": {
    "Video": {
      "title": "Video",
      "description": "A video item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "format": { "type": "string", "enum": ["youtube", "square", "reel"] },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "url", "format", "createdAt"]
    },
    "Photo": {
      "title": "Photo",
      "description": "A photo item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "format": { "type": "string", "enum": ["landscape", "portrait", "square"] },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "url", "format", "createdAt"]
    },
    "Screenshot": {
      "title": "Screenshot",
      "description": "A client screenshot",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "url", "createdAt"]
    },
    "SalesReport": {
      "title": "SalesReport",
      "description": "A sales report",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "url", "createdAt"]
    },
    "HeroVideo": {
      "title": "HeroVideo",
      "description": "Hero section video settings",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "backgroundUrl": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["url", "thumbnailUrl"]
    },
    "WhatWeDoVideo": {
      "title": "WhatWeDoVideo",
      "description": "A video for the What We Do section",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "url", "thumbnailUrl", "createdAt"]
    },
    "FBAdsResult": {
      "title": "FBAdsResult",
      "description": "Facebook Ads result image",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "url", "createdAt"]
    }
  },
  "firestore": {
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Collection of videos"
    },
    "/photos/{photoId}": {
      "schema": "Photo",
      "description": "Collection of photos"
    },
    "/screenshots/{screenshotId}": {
      "schema": "Screenshot",
      "description": "Collection of client screenshots"
    },
    "/salesReports/{reportId}": {
      "schema": "SalesReport",
      "description": "Collection of sales reports"
    },
    "/settings/heroVideo": {
      "schema": "HeroVideo",
      "description": "Hero video settings"
    },
    "/whatWeDoVideos/{videoId}": {
      "schema": "WhatWeDoVideo",
      "description": "Videos for the What We Do section"
    },
    "/fbAdsResults/{resultId}": {
      "schema": "FBAdsResult",
      "description": "Facebook Ads results images"
    }
  }
}
